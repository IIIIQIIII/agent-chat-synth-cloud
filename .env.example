# Copy this file to .env and fill in your API keys

# Aliyun DashScope API Keys (4 accounts for parallel processing)
ALIYUN_KEY_1=sk-your-key-1-here
ALIYUN_KEY_2=sk-your-key-2-here
ALIYUN_KEY_3=sk-your-key-3-here
ALIYUN_KEY_4=sk-your-key-4-here

# Account names (optional, for logging)
ALIYUN_NAME_1=Account1
ALIYUN_NAME_2=Account2
ALIYUN_NAME_3=Account3
ALIYUN_NAME_4=Account4

# API Configuration
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL=qwen3-coder-next

# Concurrency per account (recommended: 5)
CONCURRENCY=5

# Max conversation turns
MAX_TURNS=10
